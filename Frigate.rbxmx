        <Item class="ModuleScript" referent="11">
          <Properties>
            <string name="Name">InternalFlags</string>
            <string name="Source"><![CDATA[--[[
    Used to configure package/experimental behavior.
	The functionality of this module is reserved for internal use.
]]

local InternalTypes = script.Parent.InternalTypes

local flags: { [string]: InternalTypes.LxAttribute } = {
	["FF_SetUnreliableBehavior"] = {
		scope = "NET",
		state = false,
	},
	["FF_ForceNameOverride"] = {
		scope = "NET",
		state = nil,
	},
}

return flags
]]></string>
          </Properties>
        </Item>
        <Item class="ModuleScript" referent="12">
          <Properties>
            <string name="Name">InternalTypes</string>
            <string name="Source"><![CDATA[--[[
	Special Internal types.
	The functionality of this module is reserved for internal use.
]]

--[[
	Acts as a feature flag with a optional scope.
]]
export type LxAttribute = {
	scope: string?,
	state: any,
}
]]></string>
